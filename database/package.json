{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./schema/index.ts"
  },
  "scripts": {
    "push": "node --env-file=../.env ./node_modules/drizzle-kit/bin.cjs push --config ./drizzle.config.ts",
    "seed": "node --env-file=../.env --import tsx ./seeds/seed.ts",
    "setup": "pnpm run push && pnpm run seed"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "mysql2": "^3.22.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "bcrypt": "^6.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:"
  }
}
